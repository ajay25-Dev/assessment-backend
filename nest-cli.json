{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "question-bank/data/*.json",
        "watchAssets": true
      },
      {
        "include": "question-bank/data/sql/*.sql",
        "watchAssets": true
      },
      {
        "include": "evaluations/data/*.json",
        "watchAssets": true
      }
    ]
  }
}
